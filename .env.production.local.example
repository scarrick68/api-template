# Generated defaults for local production mode.
# Put machine-specific overrides in .env.production.local.user.

RAILS_ENV=production
RACK_ENV=production

PORT=5001
APP_HOST=localhost:5001
APP_PROTOCOL=http

DATABASE_URL=postgres://localhost:5432/my_app_development
BLAZER_DATABASE_URL=postgres://localhost:5432/my_app_development
OPENSEARCH_URL=http://127.0.0.1:9200
CORS_ALLOWED_ORIGINS=http://localhost:3000

SECRET_KEY_BASE=prod-local-debug-secret-key-base
DTA_SEND_CONFIRMATION_EMAIL=false
