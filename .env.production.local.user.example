# Local production overrides for your machine.
# Loaded after .env.production.local by bin/prod-local.
# This file should contain only values that differ from generated defaults.

# DATABASE_URL=postgres://localhost:5432/my_custom_db
# APP_HOST=localhost:5001
# CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# SECRET_KEY_BASE=replace-me-for-local-prod
# MY_OTHER_SERVICE=whatever-value-you-need
# MY_APP_GREW_AND_I_ADDED_THIS=something-else